[sub_resource type="Resource" id="Resource_2axwi"]
script = ExtResource("2_yh3wi")
NodeType = 3
Content = "Not yet, no. Did you, Ethan?"
Speaker = "Player"
Addressee = "Ethan Riggs"
DNodeId = 3
EditorPos = Vector2(140, 480)
EditorSize = Vector2(719.99963, 380.00024)

[sub_resource type="Resource" id="Resource_6fqhg"]
script = ExtResource("2_yh3wi")
NodeType = 3
Content = "Out of my way! I'm late. "
Speaker = "Player"
Addressee = "Ethan Riggs"
DNodeId = 4
EditorPos = Vector2(180, 1980)
EditorSize = Vector2(660, 380.0005)

[sub_resource type="Resource" id="Resource_m0n1h"]
script = ExtResource("2_yh3wi")
NodeType = 3
Content = "Have you seen the elemental studies classroom?"
Speaker = "Player"
Addressee = "Ethan Riggs"
DNodeId = 5
EditorPos = Vector2(160, -900)
EditorSize = Vector2(719.9999, 399.99902)

[sub_resource type="Resource" id="Resource_8dm7v"]
script = ExtResource("2_yh3wi")
Content = "Oh! I believe I do. Er, have. Do. It's there, off to the side of the hall."
Speaker = "Ethan"
Addressee = "Player"
DNodeId = 6
EditorPos = Vector2(1240, -940)
EditorSize = Vector2(820.00195, 420.00006)

[sub_resource type="Resource" id="Resource_tk7i4"]
script = ExtResource("2_yh3wi")
Content = "I did! Never thought magic would be this easy. Never thought magic existed at all, to be honest."
Speaker = "Ethan Riggs"
Addressee = "Player"
DNodeId = 7
EditorPos = Vector2(1260, 480)
EditorSize = Vector2(780.0009, 380.00073)

[sub_resource type="Resource" id="Resource_cioib"]
script = ExtResource("2_yh3wi")
Content = "Oh! Which class is it?"
Speaker = "Ethan Riggs"
Addressee = "Player"
DNodeId = 8
EditorPos = Vector2(1200, 1980)
EditorSize = Vector2(720.00024, 400)

[sub_resource type="Resource" id="Resource_5lg6w"]
script = ExtResource("2_yh3wi")
NodeType = 3
Content = "I just said I'm late..."
Speaker = "Player"
Addressee = "Ethan Riggs"
DNodeId = 9
EditorPos = Vector2(2220, 1560)
EditorSize = Vector2(419.9984, 359.99902)

[sub_resource type="Resource" id="Resource_qh5me"]
script = ExtResource("2_yh3wi")
NodeType = 3
Content = "Elemental Studies, with Henneman. Have you seen it?"
Speaker = "Player"
Addressee = "Ethan Riggs"
DNodeId = 10
LinkDNodeId = 6
EditorPos = Vector2(2200, 2300)
EditorSize = Vector2(539.99915, 380)

[sub_resource type="Resource" id="Resource_7fxov"]
script = ExtResource("2_yh3wi")
Content = "Oh right, my bad... uh, hope you find it ok!"
Speaker = "Ethan Riggs"
Addressee = "Player"
DNodeId = 11
EditorPos = Vector2(2900, 1560)
EditorSize = Vector2(579.9988, 359.99902)

[sub_resource type="Resource" id="Resource_s2aln"]
script = ExtResource("2_yh3wi")
NodeType = 3
Content = "Easy? Didn't you just start?"
Speaker = "Player"
Addressee = "Ethan Riggs"
DNodeId = 12
EditorPos = Vector2(2320, -380)
EditorSize = Vector2(619.99976, 400.00122)

[sub_resource type="Resource" id="Resource_tpj21"]
script = ExtResource("2_yh3wi")
Content = "Yes! But in my elemental studies class, they asked me to summon fire, and I was able to light a candle within the minute!"
Speaker = "Ethan Riggs"
Addressee = "Player"
DNodeId = 13
EditorPos = Vector2(3140, -380)
EditorSize = Vector2(759.99976, 420.00165)

[sub_resource type="Resource" id="Resource_b046i"]
script = ExtResource("2_yh3wi")
NodeType = 3
Content = "Yes. You must be the fastest 18 year old to learn to light a candle in history. "
Speaker = "Player"
Addressee = "Ethan Riggs"
DNodeId = 14
EditorPos = Vector2(5020, -620)
EditorSize = Vector2(640.0005, 400.00006)

[sub_resource type="Resource" id="Resource_p4vbk"]
script = ExtResource("2_yh3wi")
NodeType = 3
Content = "Don't you think that's a bit... excessive?"
Speaker = "Player"
Addressee = "Ethan Riggs"
DNodeId = 15
EditorPos = Vector2(5040, -80)
EditorSize = Vector2(620.0005, 380.00024)

[sub_resource type="Resource" id="Resource_lb5ub"]
script = ExtResource("2_yh3wi")
Content = "Do you think I'm a prodigy?"
Speaker = "Ethan Riggs"
Addressee = "Player"
DNodeId = 16
EditorPos = Vector2(4060, -380)
EditorSize = Vector2(639.99963, 440.0014)

[sub_resource type="Resource" id="Resource_3yp12"]
script = ExtResource("2_yh3wi")
Content = "Excessive?? What do you mean? It's a candle, what else was I supposed to do with it? Do you think it got hurt?"
Speaker = "Ethan Riggs"
Addressee = "Player"
DNodeId = 17
EditorPos = Vector2(6280, -60)
EditorSize = Vector2(639.9995, 439.99976)

[sub_resource type="Resource" id="Resource_8n8kl"]
script = ExtResource("2_yh3wi")
NodeType = 3
Content = "I just mean it's only a candle, you know?"
Speaker = "Player"
Addressee = "Ethan Riggs"
DNodeId = 18
EditorPos = Vector2(7180, -40)
EditorSize = Vector2(720.00146, 419.99945)

[sub_resource type="Resource" id="Resource_2nhr1"]
