EditorSize = Vector2(660.0029, 439.99274)

[sub_resource type="Resource" id="Resource_w8wmo"]
script = ExtResource("2_dm36e")
NodeType = 3
Content = "Are you in need of assistance?"
DNodeId = 281487861612548
EditorPos = Vector2(1800, 140)
EditorSize = Vector2(639.999, 360.00128)

[sub_resource type="Resource" id="Resource_n8ac3"]
script = ExtResource("2_dm36e")
NodeType = 3
Content = "Do you know the way to Stolgarode?"
DNodeId = 281492156579844
EditorPos = Vector2(1780, 1460)
EditorSize = Vector2(620, 400.00183)

[sub_resource type="Resource" id="Resource_mjyhw"]
script = ExtResource("2_dm36e")
NodeType = 3
Content = "Well, not desperate, but... a doctor would be nice."
DNodeId = 281496451547140
EditorPos = Vector2(4820, 1440)
EditorSize = Vector2(640, 399.99866)

[sub_resource type="Resource" id="Resource_5v0ru"]
script = ExtResource("2_dm36e")
Content = "It seems to me that only the desperate or the deranged would travel here alone. May I ask to which I speak?"
Speaker = "Argus"
Addressee = "Player"
DNodeId = 281496451547141
EditorPos = Vector2(3780, 800)
EditorSize = Vector2(619.9922, 459.99396)

[sub_resource type="Resource" id="Resource_05niy"]
script = ExtResource("2_dm36e")
Content = "Hm. I thought I knew. Perhaps not yet."
Speaker = "Argus"
Addressee = "Player"
DNodeId = 281496451547142
LinkDNodeId = 281500746514441
EditorPos = Vector2(5640, 200)
EditorSize = Vector2(599.9995, 339.99957)

[sub_resource type="Resource" id="Resource_aclli"]
script = ExtResource("2_dm36e")
NodeType = 3
Content = "Just tell me what you want."
DNodeId = 281500746514438
EditorPos = Vector2(4940, 200)
EditorSize = Vector2(479.99316, 359.99982)

[sub_resource type="Resource" id="Resource_3jdyt"]
script = ExtResource("2_dm36e")
Content = "Ah! How frightening. An assassin who travels without a gun. You must be skilled indeed!"
Speaker = "Argus"
Addressee = "Player"
DNodeId = 281500746514439
EditorPos = Vector2(5640, 800)
EditorSize = Vector2(599.9995, 439.99493)

[sub_resource type="Resource" id="Resource_eh7ra"]
script = ExtResource("2_dm36e")
Content = "Can't help you there, though I can provide you with a tonic... you look like you'll need it."
Speaker = "Argus"
Addressee = "Player"
DNodeId = 281500746514440
LinkDNodeId = 281500746514441
EditorPos = Vector2(5620, 1440)
EditorSize = Vector2(700.0088, 399.99915)

[sub_resource type="Resource" id="Resource_dra02"]
