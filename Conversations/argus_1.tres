EditorSize = Vector2(619.9951, 399.99695)

[sub_resource type="Resource" id="Resource_pxjla"]
script = ExtResource("2_dm36e")
NodeType = 3
Content = "Tired of life?"
DNodeId = 4294967297
EditorPos = Vector2(1800, 800)
EditorSize = Vector2(539.999, 359.99933)

[sub_resource type="Resource" id="Resource_usqqm"]
script = ExtResource("2_dm36e")
Content = "Perhaps. Perhaps not."
Speaker = "Argus"
Addressee = "Player"
DNodeId = 4294967298
LinkDNodeId = 281496451547141
EditorPos = Vector2(2600, 140)
EditorSize = Vector2(400.00098, 360.00104)

[sub_resource type="Resource" id="Resource_y0ki2"]
script = ExtResource("2_dm36e")
Content = "I can't say that I do - I'm no native, I'm afraid."
Speaker = "Argus"
Addressee = "Player"
DNodeId = 4294967299
LinkDNodeId = 281496451547141
EditorPos = Vector2(2600, 1460)
EditorSize = Vector2(619.9951, 400.0028)

