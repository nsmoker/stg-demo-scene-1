EditorSize = Vector2(400.00342, 360.00287)

[sub_resource type="Resource" id="Resource_cs57e"]
script = ExtResource("2_dm36e")
Content = "Ha! Well, I am rather tired. This place has that effect."
Speaker = "Argus"
Addressee = "Player"
DNodeId = 3
EditorPos = Vector2(2500, 800)
EditorSize = Vector2(619.99414, 400.00323)

[sub_resource type="Resource" id="Resource_lgc6r"]
script = ExtResource("2_dm36e")
NodeType = 3
Content = "Are you in need of assistance?"
DNodeId = 4294967299
EditorPos = Vector2(1720, 140)
EditorSize = Vector2(639.99756, 360.00336)

[sub_resource type="Resource" id="Resource_w8wmo"]
script = ExtResource("2_dm36e")
Content = "It seems to me that only the desperate or the deranged would travel here alone. May I ask to which I speak?"
Speaker = "Argus"
Addressee = "Player"
DNodeId = 4294967300
EditorPos = Vector2(3780, 800)
EditorSize = Vector2(619.999, 459.9975)

[sub_resource type="Resource" id="Resource_n8ac3"]
script = ExtResource("2_dm36e")
Content = "Hm. I thought I knew. Perhaps not yet."
Speaker = "Argus"
Addressee = "Player"
DNodeId = 4294967301
LinkDNodeId = 8589934599
EditorPos = Vector2(5740, -140)
EditorSize = Vector2(600.001, 340.00043)

[sub_resource type="Resource" id="Resource_mjyhw"]
script = ExtResource("2_dm36e")
NodeType = 3
Content = "Just tell me what you want."
DNodeId = 8589934597
EditorPos = Vector2(5040, -140)
EditorSize = Vector2(479.9856, 359.9992)

[sub_resource type="Resource" id="Resource_5v0ru"]
script = ExtResource("2_dm36e")
Content = "Ah! How frightening. An assassin who travels without a gun. You must be skilled indeed!"
Speaker = "Argus"
Addressee = "Player"
DNodeId = 8589934598
EditorPos = Vector2(5740, 460)
EditorSize = Vector2(600.001, 439.99744)

[sub_resource type="Resource" id="Resource_05niy"]
