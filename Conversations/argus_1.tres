[sub_resource type="Resource" id="Resource_y0ki2"]
script = ExtResource("2_dm36e")
Content = "Ho there, wanderer. Stay thy course a moment and indulge an old man."
Speaker = "Argus"
Addressee = "Player"
DNodeId = 1
EditorPos = Vector2(440, 820)
EditorSize = Vector2(619.99805, 399.99716)

[sub_resource type="Resource" id="Resource_7exsp"]
script = ExtResource("2_dm36e")
Content = "Perhaps. Perhaps not."
Speaker = "Argus"
Addressee = "Player"
DNodeId = 2
