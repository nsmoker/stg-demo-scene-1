EditorSize = Vector2(456.0083, 257.01117)

[sub_resource type="Resource" id="Resource_xm13u"]
script = ExtResource("2_u08tk")
NodeType = 3
Content = "Have any work around here?"
DNodeId = 43
EditorPos = Vector2(8300, 2580)
EditorSize = Vector2(540.01404, 399.99994)

[sub_resource type="Resource" id="Resource_21vsw"]
script = ExtResource("2_u08tk")
Content = "As a matter of fact, I have a job you could take. If you're bold, that is. I think I have an inkling of where those highwaymen have set up camp, I was hoping you'd take a look."
Speaker = "Mayor Plinth"
Addressee = "Player"
DNodeId = 44
EditorPos = Vector2(9160, 2580)
EditorSize = Vector2(699.9779, 499.99408)

