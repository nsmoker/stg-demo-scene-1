Action = SubResource("Resource_ki2qi")
EditorPos = Vector2(560, 920)
EditorSize = Vector2(456, 257.00934)

[sub_resource type="Resource" id="Resource_lsx02"]
script = ExtResource("2_u08tk")
NodeType = 3
Content = "I noticed. I found an abandoned cabin south of here, and a note saying the owner was fleeing to St. Paul."
DNodeId = 30
Condition = ExtResource("6_daedd")
EditorPos = Vector2(6600, -320)
EditorSize = Vector2(599.9907, 519.9973)

[sub_resource type="Resource" id="Resource_p67s7"]
script = ExtResource("2_u08tk")
NodeType = 3
Content = "Darian. Good to meet a friendly face."
DNodeId = 31
EditorPos = Vector2(8320, 1140)
EditorSize = Vector2(540.0122, 399.99374)

[sub_resource type="Resource" id="Resource_4dqqc"]
script = ExtResource("2_u08tk")
NodeType = 3
Content = "Nice office."
DNodeId = 32
EditorPos = Vector2(8300, 1780)
EditorSize = Vector2(540.01404, 400.02014)

[sub_resource type="Resource" id="Resource_jrg0b"]
script = ExtResource("2_u08tk")
Content = "This is the mayor's office. And I'm the Mayor, Plinth, though there's not much left to be mayor of, these days. Pleased to meet you."
Speaker = "Mayor Plinth"
Addressee = "Player"
DNodeId = 33
EditorPos = Vector2(7320, 1780)
EditorSize = Vector2(699.98474, 500.01233)

[sub_resource type="Resource" id="Resource_4od8b"]
script = ExtResource("2_u08tk")
Content = "Likewise."
Speaker = "Mayor Plinth"
Addressee = "Player"
DNodeId = 34
LinkDNodeId = 40
EditorPos = Vector2(9200, 1140)
EditorSize = Vector2(368.00073, 379.99667)

[sub_resource type="Resource" id="Resource_sbclb"]
script = ExtResource("2_u08tk")
NodeType = 3
Content = "I'll do it, as long as the pay's good."
DNodeId = 35
EditorPos = Vector2(10200, 2560)
EditorSize = Vector2(540.0155, 400.0047)

[sub_resource type="Resource" id="Resource_4t4n5"]
script = ExtResource("2_u08tk")
NodeType = 3
Content = "Don't know if I've got that in me."
DNodeId = 36
EditorPos = Vector2(10200, 3480)
EditorSize = Vector2(540.0155, 399.99225)

[sub_resource type="Resource" id="Resource_fhmjc"]
script = ExtResource("2_u08tk")
Content = "Thanks. Used to be the local bank. Used to be plenty here, before it was just a stop on the way to the quarry."
Speaker = "Mayor Plinth"
Addressee = "Player"
DNodeId = 37
EditorPos = Vector2(9200, 1780)
EditorSize = Vector2(699.9784, 500.01233)

[sub_resource type="Resource" id="Resource_hu6b8"]
script = ExtResource("2_u08tk")
NodeType = 2
DNodeId = 38
LinkDNodeId = 40
EditorPos = Vector2(11640, 1280)
EditorSize = Vector2(368.02722, 220.00308)

[sub_resource type="Resource" id="Resource_lrhx5"]
script = ExtResource("2_u08tk")
Content = "I understand. Just let me know if you change your mind."
Speaker = "Mayor Plinth"
Addressee = "Player"
DNodeId = 39
LinkDNodeId = 40
EditorPos = Vector2(11000, 3480)
EditorSize = Vector2(840.01575, 439.99225)

[sub_resource type="Resource" id="Resource_hfyx6"]
script = ExtResource("2_u08tk")
Content = "Anything else I can help with?"
Speaker = "Mayor Plinth"
Addressee = "Player"
DNodeId = 40
EditorPos = Vector2(12100, 1800)
EditorSize = Vector2(699.9811, 500.01685)

[sub_resource type="Resource" id="Resource_g6kfw"]
script = ExtResource("2_u08tk")
Content = "You can have anything that's left in the vault if you clear them out. It'd mean a lot to me. I grew up here; I don't want to live out the rest of my days in a war zone."
Speaker = "Mayor Plinth"
Addressee = "Player"
DNodeId = 41
LinkDNodeId = 40
EditorPos = Vector2(11600, 2560)
EditorSize = Vector2(840.0204, 440.00885)

