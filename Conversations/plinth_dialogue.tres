[sub_resource type="Resource" id="Resource_lt26h"]
script = ExtResource("2_u08tk")
NodeType = 2
DNodeId = 17
EditorPos = Vector2(-140, 920)
EditorSize = Vector2(368, 220.00104)

[sub_resource type="Resource" id="Resource_i6hw7"]
script = ExtResource("2_u08tk")
NodeType = 2
DNodeId = 38
LinkDNodeId = 40
EditorPos = Vector2(11640, 1280)
EditorSize = Vector2(368.02722, 220.00308)

[sub_resource type="Resource" id="Resource_2kaua"]
script = ExtResource("2_u08tk")
Content = "Well, I can tell you the folk here don't want any trouble with the order. I don't know a man named Thorn; I'd tell you if I did. "
Speaker = "Mayor Plinth"
Addressee = "Player"
DNodeId = 1
EditorPos = Vector2(3400, -2100)
EditorSize = Vector2(659.9971, 440)

[sub_resource type="Resource" id="Resource_sqw8j"]
script = ExtResource("2_u08tk")
NodeType = 3
Content = "Not exactly."
DNodeId = 2
EditorPos = Vector2(5200, -2100)
EditorSize = Vector2(640.011, 440.00098)

[sub_resource type="Resource" id="Resource_1gr2w"]
script = ExtResource("2_u08tk")
Content = "Just don't go bothering any of the residents around here. They're honest folk, you hear?"
Speaker = "Mayor Plinth"
Addressee = "Player"
DNodeId = 3
LinkDNodeId = 24
EditorPos = Vector2(6100, -2640)
EditorSize = Vector2(659.978, 439.99792)

[sub_resource type="Resource" id="Resource_s6ecb"]
script = ExtResource("2_u08tk")
Content = "Good. Nobody here would trust you if you were. "
Speaker = "Mayor Plinth"
Addressee = "Player"
DNodeId = 4
EditorPos = Vector2(6080, -2100)
EditorSize = Vector2(780.0039, 380.00024)

[sub_resource type="Resource" id="Resource_hghpu"]
script = ExtResource("2_u08tk")
NodeType = 3
Content = "(Lie) Couldn't tell from the uniform?"
DNodeId = 5
EditorPos = Vector2(5200, -2640)
EditorSize = Vector2(640.011, 439.99597)

[sub_resource type="Resource" id="Resource_msq8q"]
script = ExtResource("2_u08tk")
NodeType = 3
Content = "None of your business."
DNodeId = 6
EditorPos = Vector2(8140, -2760)
EditorSize = Vector2(640.0089, 440.0011)

[sub_resource type="Resource" id="Resource_jurh2"]
script = ExtResource("2_u08tk")
NodeType = 3
Content = "I'm not in love with them. Just need the work."
DNodeId = 7
EditorPos = Vector2(8140, -1460)
EditorSize = Vector2(640.0226, 399.9983)

[sub_resource type="Resource" id="Resource_v44os"]
script = ExtResource("2_u08tk")
Content = "And I hope to keep it that way."
Speaker = "Mayor Plinth"
Addressee = "Player"
DNodeId = 8
LinkDNodeId = 12
EditorPos = Vector2(9000, -2760)
EditorSize = Vector2(519.9977, 359.99988)

[sub_resource type="Resource" id="Resource_l0wd4"]
script = ExtResource("2_u08tk")
Content = "Good work is building things, getting something people need. Helping people. Last I checked, that's about the opposite of what the order did."
Speaker = "Mayor Plinth"
Addressee = "Player"
DNodeId = 9
EditorPos = Vector2(8980, -2100)
EditorSize = Vector2(779.95935, 440.00098)

[sub_resource type="Resource" id="Resource_2uge7"]
script = ExtResource("2_u08tk")
Content = "That I understand, though I can't promise everyone here will."
Speaker = "Mayor Plinth"
Addressee = "Player"
DNodeId = 10
LinkDNodeId = 12
EditorPos = Vector2(8960, -1460)
EditorSize = Vector2(799.9745, 399.9978)

[sub_resource type="Resource" id="Resource_knr6q"]
script = ExtResource("2_u08tk")
Content = "Can't say I do. He might be one of the miners; you could ask around at the quarry office."
Speaker = "Mayor Plinth"
Addressee = "Player"
DNodeId = 11
LinkDNodeId = 21
EditorPos = Vector2(3380, 320)
EditorSize = Vector2(659.99634, 440.00366)

[sub_resource type="Resource" id="Resource_nbbi2"]
script = ExtResource("2_u08tk")
Content = "You talk to me if you want some work that's a bit more grounded."
DNodeId = 12
LinkDNodeId = 44
EditorPos = Vector2(10260, -2100)
EditorSize = Vector2(839.9955, 419.99902)

[sub_resource type="Resource" id="Resource_vfsva"]
script = ExtResource("2_u08tk")
NodeType = 3
Content = "How do you get to Stalgarode?"
DNodeId = 13
EditorPos = Vector2(6580, 320)
EditorSize = Vector2(639.98096, 440.01147)

[sub_resource type="Resource" id="Resource_opjd3"]
script = ExtResource("2_u08tk")
NodeType = 3
Content = "I'm looking for a man named Davos Thorn; he has some business with the Order of the Dark Word."
DNodeId = 14
EditorPos = Vector2(2460, -2100)
EditorSize = Vector2(640.00073, 439.99902)

[sub_resource type="Resource" id="Resource_2pcdj"]
script = ExtResource("2_u08tk")
Content = "Really, now? That'd be James Marle's cabin, but I saw him in town just today. Real sorry to hear he's fleeing; I wonder what happened out there."
Speaker = "Mayor Plinth"
Addressee = "Player"
DNodeId = 15
EditorPos = Vector2(7440, -320)
EditorSize = Vector2(699.9933, 499.9906)

[sub_resource type="Resource" id="Resource_6gvp6"]
script = ExtResource("2_u08tk")
NodeType = 1
DNodeId = 16
Action = ExtResource("3_wf48n")
LinkDNodeId = 33
EditorPos = Vector2(8340, -320)
EditorSize = Vector2(456.01257, 257.00146)

[sub_resource type="Resource" id="Resource_fwo3a"]
script = ExtResource("2_u08tk")
NodeType = 2
DNodeId = 17
EditorPos = Vector2(-140, 920)
EditorSize = Vector2(368, 220.00104)

[sub_resource type="Resource" id="Resource_sih08"]
script = ExtResource("2_u08tk")
Content = "Greetings, traveler. Welcome to Fortuna. Forgive me if I sound unfriendly, but it's rare that we see visitors here, except for the miners, and you don't look much like a miner. What brings you here?"
Speaker = "Mayor Plinth"
Addressee = "Player"
DNodeId = 18
EditorPos = Vector2(1500, 920)
EditorSize = Vector2(679.99316, 579.9929)

[sub_resource type="Resource" id="Resource_xbc5v"]
script = ExtResource("2_u08tk")
NodeType = 3
Content = "I'm seeking rest on the way to Stalgarode. It's been a difficult road so far."
DNodeId = 19
EditorPos = Vector2(2540, 1020)
EditorSize = Vector2(639.98535, 439.98798)

[sub_resource type="Resource" id="Resource_nxoy2"]
script = ExtResource("2_u08tk")
Content = "Unfortunately, that's not surprising. It's rare for travelers to take the roads this far North, these days. The quarry mostly sends its miners directly on the railroad."
Speaker = "Mayor Plinth"
Addressee = "Player"
DNodeId = 20
EditorPos = Vector2(3380, 1020)
EditorSize = Vector2(699.9978, 499.99884)

[sub_resource type="Resource" id="Resource_sb3of"]
script = ExtResource("2_u08tk")
Content = "They're the only folk who would have the resources to keep the roads clear. So here we are."
Speaker = "Mayor Plinth"
Addressee = "Player"
DNodeId = 21
EditorPos = Vector2(4400, 1020)
EditorSize = Vector2(699.99927, 499.99884)

[sub_resource type="Resource" id="Resource_foww5"]
script = ExtResource("2_u08tk")
Content = "A lot of folk who used to live here have left on the railroad, or gone to Stalgarode."
Speaker = "Mayor Plinth"
Addressee = "Player"
DNodeId = 22
EditorPos = Vector2(5360, 1020)
EditorSize = Vector2(700.0283, 499.99884)

[sub_resource type="Resource" id="Resource_t11v2"]
script = ExtResource("2_u08tk")
Content = "Not one of them, are you?"
Speaker = "Mayor Plinth"
Addressee = "Player"
DNodeId = 23
EditorPos = Vector2(4260, -2100)
EditorSize = Vector2(659.99756, 440)

[sub_resource type="Resource" id="Resource_jr2wa"]
script = ExtResource("2_u08tk")
Content = "Can't fathom why any self-respecting man would be working with those fanatics, but that's your perogative."
Speaker = "Mayor Plinth"
Addressee = "Player"
DNodeId = 24
EditorPos = Vector2(7060, -2100)
EditorSize = Vector2(839.98926, 399.99976)

[sub_resource type="Resource" id="Resource_c0wfm"]
script = ExtResource("2_u08tk")
NodeType = 3
Content = "The order does good work."
DNodeId = 25
EditorPos = Vector2(8140, -2100)
EditorSize = Vector2(640.0089, 440.00195)

[sub_resource type="Resource" id="Resource_tfxcd"]
script = ExtResource("2_u08tk")
NodeType = 3
Content = "Do you know a man named Davos Thorn?"
DNodeId = 26
EditorPos = Vector2(2560, 320)
EditorSize = Vector2(639.9878, 440.00366)

[sub_resource type="Resource" id="Resource_dk1e4"]
script = ExtResource("2_u08tk")
NodeType = 3
Content = "What is this place? "
DNodeId = 27
EditorPos = Vector2(6560, 1780)
EditorSize = Vector2(368.00415, 360.01917)

[sub_resource type="Resource" id="Resource_3qnal"]
script = ExtResource("2_u08tk")
Content = "Just up the road to the North, across the river. It's a larger town, you can't miss it."
Speaker = "Mayor Plinth"
Addressee = "Player"
DNodeId = 28
LinkDNodeId = 33
EditorPos = Vector2(7440, 320)
EditorSize = Vector2(699.9933, 500.00684)

