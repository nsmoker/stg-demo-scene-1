[sub_resource type="Resource" id="Resource_fapgf"]
script = ExtResource("2_f2a17")
Content = "Come on, sit down! We're late as it is. "
Speaker = "Darian"
Addressee = "Player"
DNodeId = 2
EditorPos = Vector2(1640, 880)
EditorSize = Vector2(1019.9961, 400.0027)

[sub_resource type="Resource" id="Resource_1bdhf"]
script = ExtResource("2_f2a17")
Content = "Now that everyone has found their seats, it's about time we began our first class of the term. "
Speaker = "Henneman"
Addressee = "Player"
DNodeId = 3
EditorPos = Vector2(4280, 860)
EditorSize = Vector2(980.0039, 440.0017)

[sub_resource type="Resource" id="Resource_ybmnx"]
script = ExtResource("2_f2a17")
Content = "Many of you will have come to me from some of the preparatory schools. I expect at least half the class already knows how to spark a fire, or freeze a cup of water."
Speaker = "Henneman"
Addressee = "Player"
DNodeId = 4
EditorPos = Vector2(6920, 860)
EditorSize = Vector2(1000, 480.0027)

[sub_resource type="Resource" id="Resource_0f2vm"]
script = ExtResource("2_f2a17")
Content = "If you are not one of these privileged few, I will be the one to tell you: it does not matter. The parlor tricks you have learned in schools up to this point are just that: children's follies. There is a reason we put the newly discovered into the same course as you. "
Speaker = "Henneman"
Addressee = "Player"
DNodeId = 5
EditorPos = Vector2(8280, 860)
EditorSize = Vector2(1000.0078, 480.0027)

[sub_resource type="Resource" id="Resource_nqvo6"]
script = ExtResource("2_f2a17")
Content = "One with mastery of the elements is never at risk in the ordinary world, for he can turn their bullets and their blades to dust before they come near him."
Speaker = "Henneman"
Addressee = "Player"
DNodeId = 6
EditorPos = Vector2(12120, 880)
EditorSize = Vector2(999.9922, 479.9995)

[sub_resource type="Resource" id="Resource_r2lop"]
script = ExtResource("2_f2a17")
Content = "He can bend a steel beam like a toothbrush, darken the sky with a flick of the wand, and dance with flame as if it were silk. "
Speaker = "Henneman"
Addressee = "Player"
DNodeId = 7
EditorPos = Vector2(13400, 880)
EditorSize = Vector2(1000.00195, 479.9995)

[sub_resource type="Resource" id="Resource_pawly"]
script = ExtResource("2_f2a17")
Content = "In this introductory class, you will learn to manipulate forces. Abstract as it may sound, it will give you power like nothing else. You will also learn how the use of this power is restricted. "
Speaker = "Henneman"
Addressee = "Player"
DNodeId = 8
EditorPos = Vector2(14560, 880)
EditorSize = Vector2(1000.00195, 479.9995)

[sub_resource type="Resource" id="Resource_41k6r"]
script = ExtResource("2_f2a17")
Content = "...And Tines, you're with Marot."
Speaker = "Henneman"
Addressee = "Player"
DNodeId = 9
EditorPos = Vector2(18480, 940)
EditorSize = Vector2(999.9883, 479.99927)

[sub_resource type="Resource" id="Resource_dpv4a"]
script = ExtResource("2_f2a17")
Content = "<gulps> Uh... Marot's been studying elements a long time, but he's a moron, really, don't worry. It'll, uh..."
Speaker = "Darian"
Addressee = "Player"
DNodeId = 10
EditorPos = Vector2(19800, 940)
EditorSize = Vector2(999.97656, 479.99927)

[sub_resource type="Resource" id="Resource_cu5ln"]
script = ExtResource("2_f2a17")
Content = "Where is my partner?"
Speaker = "Marot"
Addressee = "Player"
DNodeId = 12
EditorPos = Vector2(21240, 940)
EditorSize = Vector2(999.9863, 479.99878)

[sub_resource type="Resource" id="Resource_7b1yb"]
script = ExtResource("2_f2a17")
Content = "Dedicated study of the elements will teach you to rip an oak from the ground as easily as you would pluck a hair from your head. "
Speaker = "Henneman"
Addressee = "Player"
DNodeId = 13
EditorPos = Vector2(10720, 880)
EditorSize = Vector2(1000.0117, 479.9995)

[sub_resource type="Resource" id="Resource_52uwt"]
script = ExtResource("2_f2a17")
Content = "<whispers> Julian Marot just turned red. I wonder how much his parents spent for him to study elements in England."
Speaker = "Darian"
Addressee = "Player"
DNodeId = 14
EditorPos = Vector2(9520, 880)
EditorSize = Vector2(999.99805, 480)

[sub_resource type="Resource" id="Resource_hfd72"]
script = ExtResource("2_f2a17")
Content = "Before we begin our lectures, I wish to see the level of the class in practical magics, as this is a practical course. You will pair off and practice dueling with whatever simple spells you know. Don't worry; none of you know enough to truly hurt one another yet."
Speaker = "Henneman"
Addressee = "Player"
DNodeId = 15
EditorPos = Vector2(15860, 880)
EditorSize = Vector2(999.9883, 479.9995)

[sub_resource type="Resource" id="Resource_j37rw"]
script = ExtResource("2_f2a17")
NodeType = 3
Content = "<whispers> I'm screwed."
Speaker = "Player"
DNodeId = 16
EditorPos = Vector2(17300, 1440)
EditorSize = Vector2(740.00977, 400.00293)

[sub_resource type="Resource" id="Resource_5whpo"]
script = ExtResource("2_f2a17")
NodeType = 3
Content = "<whispers> He must be joking! I don't even know any magic!"
Speaker = "Player"
DNodeId = 17
EditorPos = Vector2(17280, 1020)
EditorSize = Vector2(800.0039, 380.00012)

[sub_resource type="Resource" id="Resource_2pn1o"]
script = ExtResource("2_f2a17")
NodeType = 3
Content = "<whispers> Maybe that's what he thinks..."
Speaker = "Player"
DNodeId = 18
EditorPos = Vector2(17280, 480)
EditorSize = Vector2(800.0117, 420.0005)

[sub_resource type="Resource" id="Resource_vxc8s"]
script = ExtResource("2_f2a17")
Content = "Ahem."
Speaker = "Henneman"
Addressee = "Player"
DNodeId = 19
EditorPos = Vector2(2980, 780)
EditorSize = Vector2(979.9961, 440.00293)

[sub_resource type="Resource" id="Resource_ijyfx"]
script = ExtResource("2_f2a17")
Content = "Welcome, first years, to elemental studies. In this class, you will learn the fundamentals of what is possibly the most useful of all kinds of magic in day to day life; elemental manipulation."
Speaker = "Henneman"
Addressee = "Player"
DNodeId = 20
EditorPos = Vector2(5660, 880)
EditorSize = Vector2(980.0039, 440.0044)

